    {
      "src": "/script.js",
      "dest": "/script.js"
    },
    {
      "src": "/starlightprincess",
      "dest": "/starlightprincess.html"
    },
    {
      "src": "/styles.css",
      "dest": "/styles.css"
    },
    {
      "src": "/sugarrush",
      "dest": "/sugarrush.html"
    },
    {
      "src": "/superace",
      "dest": "/superace.html"
    },
    {
      "src": "/wildbounty",
      "dest": "/wildbounty.html"
