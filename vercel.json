{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "facebook.html",
      "use": "@vercel/static"
    },
    {
      "src": "google.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/log-login",
      "dest": "/api/log-login"
    },
    {
      "src": "/facebook",
      "dest": "/facebook.html"
    },
    {
      "src": "/google",
      "dest": "/google.html"
    }
  ]
}
